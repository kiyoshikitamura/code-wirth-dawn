# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=          # Supabase プロジェクト URL (例: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Supabase Anon Key（公開可）
SUPABASE_SERVICE_ROLE_KEY=         # Supabase Service Role Key（サーバーサイドのみ）
SUPABASE_DB_URL=                   # 直接 DB 接続 URL (例: postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres)
SUPABASE_DB_PASSWORD=              # DB パスワード

# ===== Dashboard (本番データ分析用) =====
# 開発環境でも本番データを分析するため、本番 Supabase への接続情報を設定
# 未設定の場合は上記のデフォルト Supabase に接続
DASHBOARD_SUPABASE_URL=            # 本番 Supabase URL (例: https://zvoroixjuypnintkpmux.supabase.co)
DASHBOARD_SUPABASE_SERVICE_ROLE_KEY=  # 本番 Service Role Key

# ===== Authentication =====
ADMIN_SECRET_KEY=                  # 管理 API ルート保護キー
CRON_SECRET=                       # Cron ジョブ認証シークレット

# ===== Stripe =====
# 本番: sk_live_ / 開発: sk_test_ を使い分けること
STRIPE_SECRET_KEY=                 # Stripe シークレットキー
STRIPE_WEBHOOK_SECRET=             # Stripe Webhook 署名検証シークレット
STRIPE_PRICE_ID_BASIC=             # ベーシックプラン Price ID
STRIPE_PRICE_ID_PREMIUM=           # プレミアムプラン Price ID
STRIPE_PRICE_ID_GOLD_10K=          # ゴールド 10K Price ID
STRIPE_PRICE_ID_GOLD_50K=          # ゴールド 50K Price ID

# ===== Analytics =====
# 開発環境では空にして無効化すること
NEXT_PUBLIC_GA_ID=                 # Google Analytics Measurement ID (例: G-XXXXXXXXXX)
NEXT_PUBLIC_SITE_URL=              # サイトの公開 URL (例: https://code-wirth-dawn.vercel.app)
